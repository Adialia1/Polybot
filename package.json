{
  "name": "polybot",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "bot": "tsx src/bot.ts",
    "positions": "tsx src/index.ts positions",
    "trades": "tsx src/index.ts trades",
    "status": "tsx src/scripts/status.ts",
    "check-balance": "tsx src/index.ts check-balance",
    "find-market": "tsx src/scripts/findMarket.ts",
    "test-trade": "tsx src/scripts/testTrade.ts",
    "approve": "tsx src/scripts/approve.ts",
    "quick-test": "tsx src/scripts/quickTest.ts",
    "sell": "tsx src/scripts/sellPosition.ts",
    "test-sell": "tsx src/scripts/testSell.ts",
    "integration-test": "tsx src/scripts/integrationTest.ts",
    "test-ws": "tsx src/scripts/testWebSocket.ts",
    "monitor": "tsx src/scripts/monitorPositions.ts",
    "test-reconcile": "tsx src/scripts/testReconciliation.ts",
    "test-orders": "tsx src/scripts/testOrders.ts",
    "test-protection": "tsx src/scripts/testProtection.ts",
    "lint": "tsc --noEmit",
    "security-check": "npm audit",
    "release:major": "./scripts/release.sh major",
    "release:minor": "./scripts/release.sh minor",
    "release:patch": "./scripts/release.sh patch",
    "prepare": "npm run build"
  },
  "keywords": [
    "polymarket",
    "trading",
    "bot",
    "copy-trading",
    "prediction-markets",
    "automated-trading"
  ],
  "author": "",
  "license": "MIT",
  "description": "Automated trade copying bot for Polymarket with risk management, multi-trader support, and Telegram notifications",
  "repository": {
    "type": "git",
    "url": "https://github.com/Adialia1/polybot.git"
  },
  "bugs": {
    "url": "https://github.com/Adialia1/polybot/issues"
  },
  "homepage": "https://github.com/Adialia1/polybot#readme",
  "dependencies": {
    "@polymarket/clob-client": "5.7.0",
    "@scure/bip32": "2.0.1",
    "@scure/bip39": "2.0.1",
    "@types/node": "25.3.5",
    "axios": "1.13.6",
    "dotenv": "17.3.1",
    "node-telegram-bot-api": "^0.67.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "viem": "2.47.2",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/ws": "8.18.1"
  }
}
