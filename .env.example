# ============================================
# POLYBOT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values

# === REQUIRED: WALLET CREDENTIALS ===
# Your wallet private key (keep secret!)
PRIVATE_KEY=0xYourPrivateKeyHere

# Your Polymarket proxy wallet address (from polymarket.com settings)
FUNDER_ADDRESS=0xYourProxyWalletAddress

# Polymarket API credentials (derived from your wallet)
POLY_API_KEY=your-api-key
POLY_API_SECRET=your-api-secret
POLY_PASSPHRASE=your-passphrase

# === WALLETS TO TRACK ===
# Comma-separated wallet addresses to copy trades from
TRACK_WALLETS=0x2005d16a84ceefa912d4e380cd32e7ff827875ea

# Friendly names for each wallet (same order as TRACK_WALLETS)
WALLET_ALIASES=RN1

# Allocation percentage for each wallet (same order, must sum to <= 100)
WALLET_ALLOCATIONS=100

# === POSITION SIZING ===
# Your total account size in USD
USER_ACCOUNT_SIZE=100

# Maximum USD per single trade
MAX_POSITION_SIZE=10

# Minimum USD per trade (skip smaller trades)
MIN_TRADE_SIZE=1

# Maximum percentage of account per trade
MAX_PERCENTAGE_PER_TRADE=10

# === TRADING MODE ===
# Set to false for real trading (START WITH true!)
DRY_RUN=true

# Copy sell signals from traders (false = buy-only mode)
COPY_SELLS=true

# How to handle conflicting signals: first, skip, majority, highest_allocation
CONFLICT_STRATEGY=first

# === RISK MANAGEMENT ===
# Stop loss percentage (negative number, e.g., -25 = sell at 25% loss)
STOP_LOSS_PERCENT=-25

# Take profit percentage (e.g., 100 = sell at 100% gain)
TAKE_PROFIT_PERCENT=100

# Trailing stop percentage from peak (0 = disabled)
TRAILING_STOP_PERCENT=0

# Maximum daily loss in USD before stopping (0 = disabled)
DAILY_LOSS_LIMIT=0

# Maximum concurrent open positions (0 = unlimited)
MAX_OPEN_POSITIONS=0

# Auto-sell positions after X hours (0 = disabled)
MAX_HOLD_TIME_HOURS=0

# === TRADE FILTERING ===
# Minimum probability to trade (0.05 = 5%)
MIN_PROBABILITY=0.05

# Maximum probability to trade (0.95 = 95%)
MAX_PROBABILITY=0.95

# Maximum bid/ask spread (0.10 = 10%)
MAX_SPREAD=0.10

# Skip markets containing these keywords (comma-separated)
BLACKLIST_KEYWORDS=

# Only trade markets containing these keywords (comma-separated, empty = all)
WHITELIST_KEYWORDS=

# === RETRY SETTINGS ===
# Maximum retry attempts for failed orders
MAX_RETRIES=3

# Base delay between retries in milliseconds
RETRY_DELAY_MS=2000

# Delay before copying a trade in milliseconds
COPY_DELAY_MS=0

# === TELEGRAM NOTIFICATIONS ===
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Get your chat ID from @userinfobot on Telegram
TELEGRAM_CHAT_ID=

# === HEALTH CHECK ENDPOINT ===
# Enable HTTP health check server
HEALTH_CHECK_ENABLED=false

# Port for health check server
HEALTH_CHECK_PORT=3000

# === WEB DASHBOARD ===
# Enable web dashboard
DASHBOARD_ENABLED=false

# Port for web dashboard
DASHBOARD_PORT=8080

# === POLLING INTERVALS ===
# How often to check for new trades (milliseconds)
POLLING_INTERVAL_MS=1000

# How often to check trailing stops (milliseconds)
TRAILING_STOP_CHECK_INTERVAL_MS=60000

# How often to check stop loss/take profit (milliseconds)
RISK_CHECK_INTERVAL_MS=30000
