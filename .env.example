# Polymarket Trade Copier Configuration

# Wallets to track (JSON array)
# Example: [{"address":"0x123...","alias":"Whale1","enabled":true}]
TRACK_WALLETS=

# Polling interval in milliseconds (default: 3000)
POLLING_INTERVAL_MS=3000

# Delay before copying trade in milliseconds (default: 500)
COPY_DELAY_MS=500

# Maximum position size in USD (default: 100)
MAX_POSITION_SIZE=100

# Minimum trade size in USD (default: 5)
MIN_TRADE_SIZE=5

# === Trading Configuration ===

# Enable trade execution (default: false)
ENABLE_TRADING=false

# Dry run mode - simulate trades without executing (default: true)
# Set to false to execute real trades
DRY_RUN=true

# Your Polygon wallet private key (required for trading)
# WARNING: Keep this secret! Never commit to git!
PRIVATE_KEY=

# Your funder/proxy wallet address (optional, for Magic/email wallets)
FUNDER_ADDRESS=

# === Probability Filters ===

# Skip trades with probability below this (default: 0.05 = 5%)
MIN_PROBABILITY=0.05

# Skip trades with probability above this (default: 0.95 = 95%)
MAX_PROBABILITY=0.95
