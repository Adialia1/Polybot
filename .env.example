# Polymarket Trade Copier Configuration

# Wallets to track (JSON array)
# Example: [{"address":"0x123...","alias":"Whale1","enabled":true}]
TRACK_WALLETS=

# Polling interval in milliseconds (default: 3000)
POLLING_INTERVAL_MS=3000

# Delay before copying trade in milliseconds (default: 500)
COPY_DELAY_MS=500

# Maximum position size in USD (default: 100)
MAX_POSITION_SIZE=100

# Minimum trade size in USD (default: 5)
MIN_TRADE_SIZE=5

# === Trading Configuration (for future implementation) ===

# Your Polygon wallet private key (for executing trades)
# PRIVATE_KEY=

# Your funder address (proxy wallet address)
# FUNDER_ADDRESS=
